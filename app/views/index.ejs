<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Cloud DevOps - Files</title>
  <style>
    body { font-family: system-ui, sans-serif; max-width: 820px; margin: 2rem auto; padding: 0 1rem; color: #1b1b2f; }
    h1 { color: #b3005e; }
    .banner { background: #eef; border-left: 4px solid #b3005e; padding: .6rem 1rem; border-radius: 4px; margin-bottom: 1.5rem; }
    table { width: 100%; border-collapse: collapse; }
    th, td { text-align: left; padding: .5rem .6rem; border-bottom: 1px solid #ddd; }
    th { background: #f6f6fa; }
    a.btn { display: inline-block; background: #b3005e; color: #fff; padding: .55rem 1rem; border-radius: 6px; text-decoration: none; }
    .empty { color: #777; font-style: italic; }
    .muted { color: #777; font-size: .9rem; }
  </style>
</head>
<body>
  <h1>Stored Files</h1>

  <% if (welcomeMessage) { %>
    <div class="banner">🔐 <%= welcomeMessage %></div>
  <% } %>

  <p><a class="btn" href="/upload">⬆ Upload a new file (Web Page 2)</a></p>

  <% if (blobs.length === 0) { %>
    <p class="empty">No files yet. Upload one to get started.</p>
  <% } else { %>
    <table>
      <thead>
        <tr><th>File</th><th>Size</th><th>Last modified</th><th>Download</th></tr>
      </thead>
      <tbody>
        <% blobs.forEach(function (b) { %>
          <tr>
            <td><%= b.name %></td>
            <td><%= b.size != null ? (b.size / 1024).toFixed(1) + " KB" : "-" %></td>
            <td class="muted"><%= b.lastModified ? new Date(b.lastModified).toLocaleString() : "-" %></td>
            <td><a href="/download/<%= encodeURIComponent(b.name) %>">Download</a></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</body>
</html>
