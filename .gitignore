*.tfstate.bak
*.backup.bak
# Generated by the bootstrap script (contains the remote-state account name)
terraform/backend.hcl

# Node.js application
app/node_modules/
app/npm-debug.log*
*.zip

# OS / editor
.DS_Store
Thumbs.db
# Microsoft Office temporary lock files
~$*
